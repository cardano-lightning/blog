digraph Script_Execution_Thread {
  rankdir=TD;
  graph [pad="0.02", nodesep="0.6", ranksep="0.5"];
  node [shape=rect, style="filled", fillcolor="#f9f9f9", fontname="Courier New", fontsize="10"];
  edge [arrowhead=none, headport="n", tailport="s", color="#aaa", fontname="Courier New", fontsize="10"];

    D2_ScriptThreadTx1 [label=<
      <TABLE CELLSPACING="0" CELLPADDING="4" BORDER="1" CELLBORDER="0" style="rounded, filled" fillcolor="#333333" color="#aaa">
        <TR>
          <TD align="center"><b>Initial Tx</b></TD>
        </TR>
        <TR>
          <TD cellpadding="0" align="left">
            <TABLE CELLSPACING="0" CELLPADDING="4" BORDER="0" CELLBORDER="1" color="#888">
              <TR>
                <TD align="center"><b>No</b> Action.<br />Contract Output <b>not</b> consumed</TD>
              </TR>
            </TABLE>
          </TD>
        </TR>
        <TR>
          <TD> </TD>
        </TR>
      </TABLE>
    > color="#aaa" shape="plain" style="filled, rounded"];

    D2_ScriptThreadTx1 -> D2_ScriptThreadTx1Input;
    D2_ScriptThreadTx1Input [label=<
      <TABLE CELLSPACING="0" CELLPADDING="4" BORDER="0" CELLBORDER="1" color="#aaa">
        <TR>
          <TD colspan="2" align="center"><b>Contract Output</b></TD>
        </TR>
        <TR>
          <TD colspan="2" align="center">Contract State <b>S</b></TD>
        </TR>
      </TABLE>
    > shape="plain" border="1" color="#000"]
    D2_ScriptThreadTx1Input -> D2_ScriptThreadTx2;


    D2_ScriptThreadTx2ExtraInput1 [shape=point];
    D2_ScriptThreadTx2ExtraInput1 -> D2_ScriptThreadTx2;

    D2_ScriptThreadTx2ExtraInput2 [shape=point];
    D2_ScriptThreadTx2ExtraInput2 -> D2_ScriptThreadTx2;

    // --- New for D2 ---
    D2_ScriptThreadTx2 [label=<
      <TABLE CELLSPACING="0" CELLPADDING="4" BORDER="1" CELLBORDER="0" style="rounded" color="#aaa">
        <TR>
          <TD align="center"><b>Tx</b></TD>
        </TR>
        <TR>
          <TD cellpadding="0" align="left">
            <TABLE CELLSPACING="0" CELLPADDING="4" BORDER="0" CELLBORDER="1" color="#aaa">
              <TR>
                <TD align="center">Action <b>X</b></TD>
              </TR>
            </TABLE>
          </TD>
        </TR>
        <TR>
          <TD> </TD>
        </TR>
      </TABLE>
    > color="#aaa" shape="plain" style="filled, rounded"];

    D2_ScriptThreadTx2Output [label=<
      <TABLE CELLSPACING="0" CELLPADDING="4" BORDER="0" CELLBORDER="1" color="#aaa">
        <TR>
          <TD colspan="2" align="center"><b>Contract Output</b></TD>
        </TR>
        <TR>
          <TD colspan="2" align="center">Contract State <b>T</b></TD>
        </TR>
      </TABLE>
    > shape="plain" border="1" color="#000"]

    D2_ScriptThreadTx2 -> D2_ScriptThreadTx2Output;

    D2_ScriptThreadTx2ExtraOutput1 [shape=point];
    D2_ScriptThreadTx2 -> D2_ScriptThreadTx2ExtraOutput1;


    D2_ScriptThreadTx2Output -> D2_ScriptThreadTx3;

    D2_ScriptThreadTx3ExtraInput1 [shape=point];
    D2_ScriptThreadTx3ExtraInput1 -> D2_ScriptThreadTx3;

    D2_ScriptThreadTx3ExtraInput2 [shape=point];
    D2_ScriptThreadTx3ExtraInput2 -> D2_ScriptThreadTx3;

    D2_ScriptThreadTx3ExtraInput3 [shape=point];
    D2_ScriptThreadTx3ExtraInput3 -> D2_ScriptThreadTx3;

    // --- New for D2 ---
    D2_ScriptThreadTx3 [label=<
      <TABLE CELLSPACING="0" CELLPADDING="4" BORDER="1" CELLBORDER="0" style="rounded" color="#aaa">
        <TR>
          <TD align="center"><b>Tx</b></TD>
        </TR>
        <TR>
          <TD cellpadding="0" align="left">
            <TABLE CELLSPACING="0" CELLPADDING="4" BORDER="0" CELLBORDER="1" color="#aaa">
              <TR>
                <TD align="center">Action <b>Y</b></TD>
              </TR>
            </TABLE>
          </TD>
        </TR>
        <TR>
          <TD> </TD>
        </TR>
      </TABLE>
    > color="#aaa" shape="plain" style="filled, rounded"];

     D2_ScriptThreadTx3Output [label=<
      <TABLE CELLSPACING="0" CELLPADDING="4" BORDER="0" CELLBORDER="1" color="#aaa">
        <TR>
          <TD colspan="2" align="center"><b>Contract Output</b></TD>
        </TR>
        <TR>
          <TD colspan="2" align="center">Contract State <b>U</b></TD>
        </TR>
      </TABLE>
    > shape="plain" border="1" color="#000"]

    D2_ScriptThreadTx3 -> D2_ScriptThreadTx3Output;

    D2_ScriptThreadTx3ExtraOutput1 [shape=point];
    D2_ScriptThreadTx3 -> D2_ScriptThreadTx3ExtraOutput1

    D2_ScriptThreadTx4 [label=<
      <TABLE CELLSPACING="0" CELLPADDING="4" BORDER="1" CELLBORDER="0" style="rounded" color="#aaa">
        <TR>
          <TD align="center"><b>Closing Tx</b></TD>
        </TR>
        <TR>
          <TD cellpadding="0" align="left">
            <TABLE CELLSPACING="0" CELLPADDING="4" BORDER="0" CELLBORDER="1" color="#aaa">
              <TR>
                <TD align="center">Action <b>Z</b>.<br /><b>No</b> continuing output.</TD>
              </TR>
            </TABLE>
          </TD>
        </TR>
        <TR>
          <TD> </TD>
        </TR>
      </TABLE>
    > color="#aaa" shape="plain" style="filled, rounded"];

    D2_ScriptThreadTx3Output -> D2_ScriptThreadTx4;

    D2_ScriptThreadTx4ExtraInput1 [shape=point];
    D2_ScriptThreadTx4ExtraInput1 -> D2_ScriptThreadTx4;

    D2_ScriptThreadTx4ExtraInput2 [shape=point];
    D2_ScriptThreadTx4ExtraInput2 -> D2_ScriptThreadTx4;

    D2_ScriptThreadTx4ExtraOutput1 [shape=point];
    D2_ScriptThreadTx4 -> D2_ScriptThreadTx4ExtraOutput1

    D2_ScriptThreadTx4ExtraOutput2 [shape=point];
    D2_ScriptThreadTx4 -> D2_ScriptThreadTx4ExtraOutput2;

    D2_ScriptThreadTx4ExtraOutput3 [shape=point];
    D2_ScriptThreadTx4 -> D2_ScriptThreadTx4ExtraOutput3;

}
